# ===========================================
# 🔐 セキュリティ（必須・最優先で設定）
# ===========================================
# Discordユーザーホワイトリスト。**空のままだとBotは全メッセージを拒否します**。
# 自分のDiscordユーザーIDをカンマ区切りで列挙してください。
# 取得方法: Discord 設定 → 詳細設定 → 「開発者モード」をON
#         → 自分のアイコンを右クリック → 「ユーザーIDをコピー」
# 例: ALLOWED_USER_IDS=123456789012345678,987654321098765432
ALLOWED_USER_IDS=

# ===========================================
# 必須
# ===========================================
DISCORD_TOKEN=your_discord_bot_token
WORK_DIR=/home/yourusername/dev/projects

# ===========================================
# Claude 実行設定
# ===========================================
DB_PATH=/home/yourusername/discord-bot/sessions.db
CLAUDE_BIN=claude
MAX_CONCURRENT=3

# ===========================================
# 公式API（Claude Code側でOAuth済みなら不要）
# ===========================================
ANTHROPIC_API_KEY=sk-ant-xxx_optional

# ===========================================
# 画像生成（オプション、Gemini/Cloudflare）
# ===========================================
GEMINI_API_KEY=optional_for_image_gen
GEMINI_API_KEY_AGS=optional_alt_account
CLOUDFLARE_ACCOUNT_ID=optional
CLOUDFLARE_API_TOKEN=optional

# ===========================================
# Anthropic Console（請求分離用、オプション）
# ===========================================
ANTHROPIC_API_KEY_CONSOLE=optional
